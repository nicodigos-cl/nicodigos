// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------------------------
// Better Auth core schema
// https://www.better-auth.com/docs/concepts/database#core-schema
// ---------------------------------------------------------------------------

enum UserRole {
  USER
  ADMIN
}

/// Administrative access state (independent of Better Auth session validity).
enum UserAccountStatus {
  ACTIVE
  RESTRICTED
  SUSPENDED
  ANONYMIZED
}

enum UserAdminNoteCategory {
  SUPPORT
  RISK
  FRAUD
  BILLING
  DELIVERY
  REFUND
  OTHER
}

enum UserAdminNotePriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum UserAdminEventType {
  ACCOUNT_CREATED
  EMAIL_VERIFIED
  PROFILE_UPDATED
  BILLING_UPDATED
  ROLE_CHANGED
  ACCOUNT_RESTRICTED
  ACCOUNT_SUSPENDED
  ACCOUNT_RESTORED
  SESSION_REVOKED
  SESSIONS_REVOKED_ALL
  PASSWORD_RESET_SENT
  EMAIL_VERIFICATION_SENT
  NOTE_ADDED
  NOTE_UPDATED
  NOTE_RESOLVED
  NOTE_REOPENED
  NOTE_DELETED
  REVIEW_MARKED
  REVIEW_RESOLVED
  ANONYMIZED
  OAUTH_UNLINKED
}

/// Preferred Chilean tax document for checkout (SII DTE).
enum InvoiceDocumentType {
  BOLETA
  FACTURA
}

model User {
  id            String   @id
  name          String
  email         String
  emailVerified Boolean  @default(false)
  image         String?
  role          UserRole @default(USER)

  accountStatus     UserAccountStatus @default(ACTIVE)
  suspensionReason  String?
  suspendedAt       DateTime?
  suspendedByUserId String?
  suspensionEndsAt  DateTime?
  requiresReview    Boolean           @default(false)
  reviewReason      String?
  lastActivityAt    DateTime?
  anonymizedAt      DateTime?

  /// Chilean RUT normalized as "12345678-9" (optional for boleta; required for factura / >135 UF).
  rut              String?
  phone            String?
  /// Default document type at checkout.
  invoiceType      InvoiceDocumentType @default(BOLETA)
  /// Razón social — required when invoiceType is FACTURA.
  businessName     String?
  /// Giro comercial — required when invoiceType is FACTURA.
  businessActivity String?
  addressLine1     String?
  addressLine2     String?
  commune          String?
  city             String?
  region           String?

  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  sessions                Session[]
  accounts                Account[]
  orders                  Order[]
  cart                    Cart?
  wishlist                Wishlist?
  adminNotes              UserAdminNote[]
  adminEvents             UserAdminEvent[]
  communicationThreads    CommunicationThread[]
  communicationPreference CommunicationPreference?
  webPushSubscriptions    WebPushSubscription[]

  @@unique([email])
  @@index([rut])
  @@index([role])
  @@index([accountStatus])
  @@index([createdAt])
  @@index([lastActivityAt])
  @@index([requiresReview])
  @@map("user")
}

model UserAdminNote {
  id           String                @id @default(cuid())
  userId       String
  user         User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  authorUserId String?
  authorEmail  String?
  category     UserAdminNoteCategory
  priority     UserAdminNotePriority @default(MEDIUM)
  content      String
  resolvedAt   DateTime?
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt

  @@index([userId, createdAt])
  @@index([userId, resolvedAt])
  @@map("user_admin_notes")
}

model UserAdminEvent {
  id          String             @id @default(cuid())
  userId      String
  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        UserAdminEventType
  actorUserId String?
  actorEmail  String?
  message     String?
  metadata    Json?
  createdAt   DateTime           @default(now())

  @@index([userId, createdAt])
  @@index([type, createdAt])
  @@map("user_admin_events")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

// ---------------------------------------------------------------------------
// Store enums
// ---------------------------------------------------------------------------

enum DeliveryMethod {
  SMM
  KINGUIN
  MANUAL
}

/// Snapshot of delivery ETA promised to the buyer at checkout / PDP.
enum DeliveryPromise {
  INSTANT
  DELAYED_12_24H
  UNAVAILABLE
}

enum ProductStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum OrderStatus {
  PENDING
  PAID
  PROCESSING
  FULFILLED
  PARTIALLY_FULFILLED
  CANCELED
  REFUNDED
}

enum DeliveryStatus {
  PENDING
  QUEUED
  PROCESSING
  DELIVERED
  FAILED
  MANUAL_REVIEW
  CANCELED
}

enum OutboxEventType {
  DELIVERY_REQUESTED
}

enum OutboxEventStatus {
  PENDING
  PROCESSING
  PUBLISHED
  FAILED
}

enum DeliveryEventSource {
  SYSTEM
  WEBHOOK
  ADMIN
}

enum DeliveryContentType {
  PRODUCT_KEY
  CODE
  PIN
  USERNAME_PASSWORD
  EMAIL_PASSWORD
  TOKEN
  URL
  INSTRUCTIONS
  FREE_TEXT
  OTHER
}

enum DeliveryNotificationType {
  COMPLETED
  FAILED
  PROCESSING
}

enum DeliveryNotificationStatus {
  PENDING
  SENT
  FAILED
}

enum ProductKeyStatus {
  AVAILABLE
  RESERVED
  SOLD
  REVOKED
}

enum PaymentStatus {
  PENDING
  PROCESSING
  PAID
  FAILED
  REJECTED
  CANCELLED
  EXPIRED
  PARTIALLY_REFUNDED
  REFUNDED
}

enum PaymentProvider {
  MANUAL
  FLOW
  OTHER
}

enum PaymentEventType {
  CREATED
  SESSION_STARTED
  CALLBACK_RECEIVED
  WEBHOOK_RECEIVED
  PROVIDER_STATUS_CHECKED
  STATUS_CHANGED
  ORDER_MARKED_PAID
  FULFILLMENT_STARTED
  RECONCILED
  CONFIRMATION_REPROCESSED
  REVIEW_MARKED
  REVIEW_RESOLVED
  NOTE_ADDED
  REFUND_REQUESTED
  REFUND_STATUS_CHECKED
  REFUND_COMPLETED
  MANUAL_CORRECTION
  ERROR
}

enum PaymentEventSource {
  SYSTEM
  CALLBACK
  WEBHOOK
  PROVIDER
  ADMIN
}

enum PaymentEventResult {
  SUCCESS
  PARTIAL
  FAILED
  IGNORED
}

enum PaymentReviewPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum PaymentRefundStatus {
  CREATED
  ACCEPTED
  REJECTED
  REFUNDED
  CANCELLED
  ERROR
}

enum SmmProviderStatus {
  ACTIVE
  INACTIVE
  ERROR
}

/// Direction of a persisted catalog price change (for UI / user notices).
enum PriceChangeDirection {
  UP
  DOWN
}

enum AssetType {
  IMAGE
  VIDEO
  YOUTUBE
}

// ---------------------------------------------------------------------------
// SMM providers & catalog services
// ---------------------------------------------------------------------------

model SmmProvider {
  id           String            @id @default(cuid())
  name         String
  slug         String            @unique
  description  String?
  apiUrl       String
  apiKey       String
  status       SmmProviderStatus @default(ACTIVE)
  isDefault    Boolean           @default(false)
  lastSyncedAt DateTime?
  lastError    String?
  services     SmmService[]
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@index([status])
  @@index([slug])
  @@map("smm_provider")
}

/// Cached remote service from an SMM panel (`SmmServiceItem`).
model SmmService {
  id              String      @id @default(cuid())
  providerId      String
  provider        SmmProvider @relation(fields: [providerId], references: [id], onDelete: Cascade)
  remoteServiceId Int
  name            String
  type            String
  category        String
  rate            Decimal     @db.Decimal(18, 6)
  min             Int
  max             Int
  refill          Boolean     @default(false)
  cancel          Boolean     @default(false)
  isActive        Boolean     @default(true)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@unique([providerId, remoteServiceId])
  @@index([providerId, category])
  @@index([providerId, name])
  @@index([remoteServiceId])
  @@map("smm_service")
}

// ---------------------------------------------------------------------------
// Catalog
// ---------------------------------------------------------------------------

model Category {
  id          String            @id @default(cuid())
  name        String
  slug        String            @unique
  description String?
  imageUrl    String?
  parentId    String?
  parent      Category?         @relation("CategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children    Category[]        @relation("CategoryTree")
  /// Sibling order within the same parent (0-based).
  sortOrder   Int               @default(0)
  products    ProductCategory[]
  assets      Asset[]
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([parentId])
  @@index([parentId, sortOrder])
  @@index([slug])
  @@map("category")
}

model Product {
  id             String         @id @default(cuid())
  name           String
  slug           String         @unique
  description    String?
  coverImageUrl  String?
  status         ProductStatus  @default(DRAFT)
  deliveryMethod DeliveryMethod

  price          Decimal  @db.Decimal(12, 2)
  compareAtPrice Decimal? @db.Decimal(12, 2)
  currency       String   @default("CLP")
  qty            Int      @default(0)
  textQty        Int?

  isFeatured Boolean @default(false)
  isOffer    Boolean @default(false)
  isPreorder Boolean @default(false)

  originalName        String?
  platform            String?
  genres              String[]  @default([])
  languages           String[]  @default([])
  developers          String[]  @default([])
  publishers          String[]  @default([])
  tags                String[]  @default([])
  regionId            Int?
  regionalLimitations String?
  countryLimitation   String[]  @default([])
  releaseDate         DateTime?
  activationDetails   String?
  ageRating           String?
  metacriticScore     Int?
  /// Acquisition cost in CLP (SMM USD→CLP or Kinguin EUR→CLP via FX).
  sourceCostPrice     Decimal?  @db.Decimal(12, 4)

  // Kinguin remote ids / sync
  kinguinProductId String?   @unique
  kinguinId        Int?      @unique
  kinguinOfferId   String?
  /// Markup % applied when pricing from Kinguin default offer EUR cost.
  kinguinMarkupPct Decimal?  @db.Decimal(8, 2)
  kinguinSyncedAt  DateTime?

  // SMM panel mapping / sync
  smmApiUrl      String?
  smmServiceId   Int?
  smmServiceType String?
  smmCategory    String?
  smmRate        Decimal?  @db.Decimal(18, 6)
  /// Markup % applied when pricing from SMM rate (e.g. 54 → ×1.54). Used to reprice on rate sync.
  smmMarkupPct   Decimal?  @db.Decimal(8, 2)
  smmMin         Int?
  smmMax         Int?
  smmRefill      Boolean?
  smmCancel      Boolean?
  smmServiceName String?
  smmSyncedAt    DateTime?

  categories         ProductCategory[]
  assets             Asset[]
  systemRequirements ProductSystemRequirement[]
  keys               ProductKey[]
  accounts           ProductAccount[]
  offers             ProductOffer[]
  orderItems         OrderItem[]
  cartItems          CartItem[]
  wishlistItems      WishlistItem[]
  priceChangeEvents  ProductPriceChangeEvent[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([deliveryMethod])
  @@index([slug])
  @@index([smmServiceId])
  @@map("product")
}

/// Short-lived audit of product price moves (cleaned by cron after retention).
/// Used to show % up/down and later notify users (cart / wishlist / etc.).
model ProductPriceChangeEvent {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  /// e.g. "smm.service.rate_changed"
  source String

  oldPrice Decimal @db.Decimal(12, 2)
  newPrice Decimal @db.Decimal(12, 2)
  currency String  @default("CLP")

  /// Relative change: ((new - old) / old) * 100. Positive = up, negative = down.
  changePct Decimal              @db.Decimal(12, 4)
  direction PriceChangeDirection

  oldSmmRate   Decimal? @db.Decimal(18, 6)
  newSmmRate   Decimal? @db.Decimal(18, 6)
  smmMarkupPct Decimal? @db.Decimal(8, 2)

  remoteServiceId Int?
  providerId      String?

  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([productId, createdAt])
  @@index([direction, createdAt])
  @@map("product_price_change_event")
}

model ProductCategory {
  id         String   @id @default(cuid())
  productId  String
  categoryId String
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([productId, categoryId])
  @@index([categoryId])
  @@map("product_category")
}

model Asset {
  id           String    @id @default(cuid())
  type         AssetType
  url          String
  objectKey    String?   @unique
  youtubeId    String?
  mimeType     String?
  fileName     String?
  sizeBytes    BigInt?
  thumbnailUrl String?
  altText      String?
  sortOrder    Int       @default(0)
  isCover      Boolean   @default(false)
  productId    String?
  product      Product?  @relation(fields: [productId], references: [id], onDelete: Cascade)
  categoryId   String?
  category     Category? @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([productId, sortOrder])
  @@index([categoryId, sortOrder])
  @@map("asset")
}

model ProductSystemRequirement {
  id           String   @id @default(cuid())
  productId    String
  product      Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  system       String
  requirements String[] @default([])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([productId])
  @@map("product_system_requirement")
}

model ProductKey {
  id            String           @id @default(cuid())
  productId     String
  product       Product          @relation(fields: [productId], references: [id], onDelete: Cascade)
  code          String
  status        ProductKeyStatus @default(AVAILABLE)
  orderItemId   String?
  orderItem     OrderItem?       @relation(fields: [orderItemId], references: [id], onDelete: SetNull)
  /// When status=RESERVED, auto-release after this timestamp if unpaid.
  reservedUntil DateTime?
  deliveryKeys  DeliveryKey[]
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@unique([productId, code])
  @@index([productId, status])
  @@index([orderItemId])
  @@index([status, reservedUntil])
  @@map("product_key")
}

/// Inventory of account credentials for MANUAL delivery auto-assign.
model ProductAccount {
  id                String              @id @default(cuid())
  productId         String
  product           Product             @relation(fields: [productId], references: [id], onDelete: Cascade)
  status            ProductKeyStatus    @default(AVAILABLE)
  contentType       DeliveryContentType @default(USERNAME_PASSWORD)
  label             String?
  username          String?
  email             String?
  /// AES-256-GCM ciphertext (base64): iv.authTag.ciphertext
  passwordEncrypted String?
  tokenEncrypted    String?
  url               String?
  notes             String?
  orderItemId       String?
  orderItem         OrderItem?          @relation(fields: [orderItemId], references: [id], onDelete: SetNull)
  reservedUntil     DateTime?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  @@index([productId, status])
  @@index([orderItemId])
  @@index([status, reservedUntil])
  @@map("product_account")
}

model ProductOffer {
  id             String    @id @default(cuid())
  productId      String
  product        Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  kinguinOfferId String    @unique
  price          Decimal   @db.Decimal(12, 4)
  qty            Int       @default(0)
  textQty        Int       @default(0)
  availableQty   Int?
  isPreorder     Boolean   @default(false)
  releaseDate    DateTime?
  merchantName   String?
  isDefault      Boolean   @default(false)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([productId])
  @@map("product_offer")
}

// ---------------------------------------------------------------------------
// Orders & delivery
// ---------------------------------------------------------------------------

model Order {
  id                   String                @id @default(cuid())
  userId               String
  user                 User                  @relation(fields: [userId], references: [id], onDelete: Restrict)
  status               OrderStatus           @default(PENDING)
  subtotal             Decimal               @db.Decimal(12, 2)
  total                Decimal               @db.Decimal(12, 2)
  currency             String                @default("CLP")
  email                String
  customerName         String?
  /// Capability token for guest order status links (emails / Flow return). High entropy; never log.
  accessToken          String                @unique
  items                OrderItem[]
  payments             Payment[]
  communicationThreads CommunicationThread[]
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt

  @@index([userId, status])
  @@index([userId, createdAt])
  @@index([status])
  @@index([createdAt])
  @@map("order")
}

model OrderItem {
  id                    String           @id @default(cuid())
  orderId               String
  order                 Order            @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId             String
  product               Product          @relation(fields: [productId], references: [id], onDelete: Restrict)
  productName           String
  unitPrice             Decimal          @db.Decimal(12, 2)
  quantity              Int
  deliveryMethod        DeliveryMethod
  /// ETA promised when the order was created (immutable snapshot).
  deliveryPromise       DeliveryPromise?
  /// Provider-side cost estimate used for the promise (USD/EUR).
  estimatedCostAmount   Decimal?         @db.Decimal(14, 6)
  estimatedCostCurrency String?
  smm                   OrderItemSmm?
  delivery              Delivery?
  productKeys           ProductKey[]
  productAccounts       ProductAccount[]
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt

  @@index([orderId])
  @@index([productId])
  @@map("order_item")
}

model OrderItemSmm {
  id              String    @id @default(cuid())
  orderItemId     String    @unique
  orderItem       OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  link            String?
  username        String?
  quantity        Int?
  comments        String?
  runs            Int?
  intervalMinutes Int?
  usernames       String?
  hashtags        String?
  mediaUrl        String?
  min             Int?
  max             Int?
  delayMinutes    Int?
  posts           Int?
  oldPosts        Int?
  expiry          String?
  answerNumber    String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@map("order_item_smm")
}

model Delivery {
  id                  String         @id @default(cuid())
  orderItemId         String         @unique
  orderItem           OrderItem      @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  status              DeliveryStatus @default(PENDING)
  /// Historical product method (never mutated for audit).
  deliveryMethod      DeliveryMethod
  /// When set (e.g. MANUAL after provider failure), worker uses this instead of deliveryMethod.
  effectiveDeliveryMethod DeliveryMethod?
  errorMessage        String?
  lastError           String?
  attemptCount        Int            @default(0)
  queuedAt            DateTime?
  processingStartedAt DateTime?
  deliveredAt         DateTime?
  failedAt            DateTime?
  idempotencyKey      String?        @unique
  customerMessage     String?
  lastSyncedAt        DateTime?

  // Remote order refs (Kinguin / SMM)
  externalOrderId String?
  externalStatus  String?
  kinguinOrderId  String?
  orderExternalId String?
  requestPriceEur Decimal? @db.Decimal(12, 4)

  // SMM progress / cost
  smmCharge     Decimal? @db.Decimal(12, 4)
  smmStartCount Int?
  smmRemains    Int?
  smmCurrency   String?
  smmRefillId   String?

  keys                 DeliveryKey[]
  credentials          DeliveryCredential[]
  events               DeliveryEvent[]
  notifications        DeliveryNotification[]
  communicationThreads CommunicationThread[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([deliveryMethod])
  @@index([externalOrderId])
  @@index([createdAt])
  @@index([updatedAt])
  @@map("delivery")
}

/// Transactional handoff from PostgreSQL to asynchronous infrastructure.
model OutboxEvent {
  id             String            @id @default(cuid())
  type           OutboxEventType
  status         OutboxEventStatus @default(PENDING)
  aggregateId    String
  idempotencyKey String            @unique
  payload        Json?
  attemptCount   Int               @default(0)
  availableAt    DateTime          @default(now())
  processingAt   DateTime?
  publishedAt    DateTime?
  lastError      String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@index([status, availableAt])
  @@index([type, aggregateId])
  @@map("outbox_event")
}

model DeliveryKey {
  id            String              @id @default(cuid())
  deliveryId    String
  delivery      Delivery            @relation(fields: [deliveryId], references: [id], onDelete: Cascade)
  serial        String
  /// Legacy / remote type string (e.g. Kinguin key type). Prefer `contentType`.
  type          String?
  contentType   DeliveryContentType @default(PRODUCT_KEY)
  label         String?
  instructions  String?
  isSecret      Boolean             @default(true)
  externalKeyId String?
  productKeyId  String?
  productKey    ProductKey?         @relation(fields: [productKeyId], references: [id], onDelete: SetNull)
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  @@unique([productKeyId])
  @@unique([externalKeyId])
  @@index([deliveryId])
  @@map("delivery_key")
}

/// Structured credentials for MANUAL deliveries (passwords/tokens encrypted at rest).
model DeliveryCredential {
  id                String              @id @default(cuid())
  deliveryId        String
  delivery          Delivery            @relation(fields: [deliveryId], references: [id], onDelete: Cascade)
  contentType       DeliveryContentType @default(USERNAME_PASSWORD)
  label             String?
  username          String?
  email             String?
  /// AES-256-GCM ciphertext (base64): iv.authTag.ciphertext
  passwordEncrypted String?
  tokenEncrypted    String?
  url               String?
  notes             String?
  instructions      String?
  isSecret          Boolean             @default(true)
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  @@index([deliveryId])
  @@map("delivery_credential")
}

model DeliveryEvent {
  id          String              @id @default(cuid())
  deliveryId  String
  delivery    Delivery            @relation(fields: [deliveryId], references: [id], onDelete: Cascade)
  status      DeliveryStatus
  message     String?
  source      DeliveryEventSource @default(SYSTEM)
  actorUserId String?
  actorEmail  String?
  createdAt   DateTime            @default(now())

  @@index([deliveryId, createdAt])
  @@index([actorUserId])
  @@map("delivery_event")
}

/// Idempotent email notification log for delivery lifecycle emails.
model DeliveryNotification {
  id             String                     @id @default(cuid())
  deliveryId     String
  delivery       Delivery                   @relation(fields: [deliveryId], references: [id], onDelete: Cascade)
  type           DeliveryNotificationType
  status         DeliveryNotificationStatus @default(PENDING)
  recipient      String
  idempotencyKey String                     @unique
  resendId       String?
  errorMessage   String?
  isResend       Boolean                    @default(false)
  sentAt         DateTime?
  createdAt      DateTime                   @default(now())
  updatedAt      DateTime                   @updatedAt

  @@index([deliveryId, type])
  @@index([status])
  @@map("delivery_notification")
}

// ---------------------------------------------------------------------------
// Payments
// ---------------------------------------------------------------------------

model Payment {
  id                  String                 @id @default(cuid())
  orderId             String
  order               Order                  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  provider            PaymentProvider        @default(OTHER)
  status              PaymentStatus          @default(PENDING)
  amount              Decimal                @db.Decimal(12, 2)
  currency            String                 @default("CLP")
  externalId          String?
  flowOrder           Int?
  commerceOrder       String?
  paymentMethod       String?
  payerEmail          String?
  providerStatus      String?
  paidAt              DateTime?
  expiresAt           DateTime?
  confirmedAt         DateTime?
  lastProviderCheckAt DateTime?
  refundAmount        Decimal                @default(0) @db.Decimal(12, 2)
  safeMetadata        Json?
  requiresReview      Boolean                @default(false)
  reviewPriority      PaymentReviewPriority?
  reviewReason        String?
  reviewNote          String?
  reviewActorUserId   String?
  reviewActorEmail    String?
  reviewCreatedAt     DateTime?
  reviewResolvedAt    DateTime?
  failureCode         String?
  failureMessage      String?
  events              PaymentEvent[]
  refunds             PaymentRefund[]
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt

  @@unique([provider, externalId])
  @@index([orderId])
  @@index([externalId])
  @@index([flowOrder])
  @@index([commerceOrder])
  @@index([status])
  @@index([requiresReview, reviewPriority])
  @@index([createdAt])
  @@map("payment")
}

model PaymentEvent {
  id             String             @id @default(cuid())
  paymentId      String
  payment        Payment            @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  type           PaymentEventType
  source         PaymentEventSource @default(SYSTEM)
  result         PaymentEventResult @default(SUCCESS)
  statusBefore   PaymentStatus?
  statusAfter    PaymentStatus?
  message        String?
  actorUserId    String?
  actorEmail     String?
  providerRef    String?
  errorCode      String?
  idempotencyKey String?            @unique
  createdAt      DateTime           @default(now())

  @@index([paymentId, createdAt])
  @@index([type, createdAt])
  @@index([actorUserId])
  @@map("payment_event")
}

model PaymentRefund {
  id                  String              @id @default(cuid())
  paymentId           String
  payment             Payment             @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  amount              Decimal             @db.Decimal(12, 2)
  currency            String
  reason              String
  status              PaymentRefundStatus @default(CREATED)
  refundCommerceOrder String              @unique
  flowRefundOrder     String?
  providerToken       String?             @unique
  providerMessage     String?
  actorUserId         String?
  actorEmail          String?
  requestedAt         DateTime            @default(now())
  completedAt         DateTime?
  updatedAt           DateTime            @updatedAt

  @@index([paymentId, status])
  @@index([status, requestedAt])
  @@map("payment_refund")
}

// ---------------------------------------------------------------------------
// Cart
// ---------------------------------------------------------------------------

model Cart {
  id             String     @id @default(cuid())
  userId         String?    @unique
  user           User?      @relation(fields: [userId], references: [id], onDelete: Cascade)
  guestTokenHash String?    @unique
  items          CartItem[]
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  @@map("cart")
}

model CartItem {
  id        String       @id @default(cuid())
  cartId    String
  cart      Cart         @relation(fields: [cartId], references: [id], onDelete: Cascade)
  productId String
  product   Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantity  Int          @default(1)
  smm       CartItemSmm?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  // No @@unique([cartId, productId]): SMM can add the same product with different links.
  @@index([cartId])
  @@index([productId])
  @@map("cart_item")
}

model CartItemSmm {
  id              String   @id @default(cuid())
  cartItemId      String   @unique
  cartItem        CartItem @relation(fields: [cartItemId], references: [id], onDelete: Cascade)
  link            String?
  username        String?
  quantity        Int?
  comments        String?
  runs            Int?
  intervalMinutes Int?
  usernames       String?
  hashtags        String?
  mediaUrl        String?
  min             Int?
  max             Int?
  delayMinutes    Int?
  posts           Int?
  oldPosts        Int?
  expiry          String?
  answerNumber    String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("cart_item_smm")
}

// ---------------------------------------------------------------------------
// Wishlist
// ---------------------------------------------------------------------------

model Wishlist {
  id        String         @id @default(cuid())
  userId    String         @unique
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     WishlistItem[]
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@map("wishlist")
}

model WishlistItem {
  id         String   @id @default(cuid())
  wishlistId String
  wishlist   Wishlist @relation(fields: [wishlistId], references: [id], onDelete: Cascade)
  productId  String
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([wishlistId, productId])
  @@index([productId])
  @@map("wishlist_item")
}

// ---------------------------------------------------------------------------
// Admin operational settings (single-row, typed — secrets stay in env)
// ---------------------------------------------------------------------------

enum StoreStatus {
  OPEN
  READ_ONLY
  MAINTENANCE
  CLOSED
}

model StoreSettings {
  id String @id @default("default")

  // General / brand
  storeName        String  @default("Nicodigos")
  legalName        String?
  shortDescription String?
  supportEmail     String  @default("soporte@nicodigos.cl")
  senderName       String  @default("Nicodigos")
  replyToEmail     String?
  primaryColor     String  @default("#E15707")
  timezone         String  @default("America/Santiago")
  locale           String  @default("es")
  country          String  @default("CL")
  defaultCurrency  String  @default("CLP")
  logoUrl          String?
  faviconUrl       String?

  // Store
  storeStatus               StoreStatus @default(OPEN)
  showOutOfStock            Boolean     @default(true)
  allowPurchaseWithoutStock Boolean     @default(false)
  pricesIncludeTax          Boolean     @default(true)
  minOrderAmount            Decimal?    @db.Decimal(12, 2)
  maxOrderAmount            Decimal?    @db.Decimal(12, 2)
  maxQuantityPerProduct     Int         @default(99)
  maxProductsPerOrder       Int         @default(50)
  supportVisible            Boolean     @default(true)
  availabilityMessage       String?

  // Checkout
  checkoutEnabled           Boolean @default(true)
  requireVerifiedEmail      Boolean @default(false)
  requireRut                Boolean @default(false)
  requireBillingData        Boolean @default(false)
  allowBoleta               Boolean @default(true)
  allowFactura              Boolean @default(true)
  orderExpirationMinutes    Int     @default(60)
  paymentExpirationMinutes  Int     @default(30)
  requireTermsAcceptance    Boolean @default(true)
  termsUrl                  String?
  privacyUrl                String?
  maxPaymentAttempts        Int     @default(5)
  reusePendingPaymentIntent Boolean @default(true)
  preventDuplicateOrders    Boolean @default(true)

  // Payments (Flow secrets remain in env)
  flowEnabled              Boolean  @default(true)
  acceptedCurrency         String   @default("CLP")
  refundsEnabled           Boolean  @default(true)
  minPaymentAmount         Decimal? @db.Decimal(12, 2)
  maxPaymentAmount         Decimal? @db.Decimal(12, 2)
  commerceOrderPrefix      String   @default("")
  strictAmountValidation   Boolean  @default(true)
  strictCurrencyValidation Boolean  @default(true)

  // Deliveries
  automaticDeliveryEnabled           Boolean @default(true)
  manualDeliveryEnabled              Boolean @default(true)
  autoSendAfterPayment               Boolean @default(false)
  deliveryRetryMax                   Int     @default(3)
  deliveryRetryIntervalMinutes       Int     @default(15)
  allowPartialDeliveries             Boolean @default(true)
  allowEmailResend                   Boolean @default(true)
  requireRecentSessionForCredentials Boolean @default(true)
  sensitiveLinkExpirationMinutes     Int     @default(60)
  hideCredentialsByDefault           Boolean @default(true)

  // Keys
  keysAutoAssign             Boolean @default(true)
  keysReserveDuringCheckout  Boolean @default(false)
  keysReserveDurationMinutes Int     @default(15)
  keysLowStockThreshold      Int     @default(5)
  keysStockAlertsEnabled     Boolean @default(true)
  keysAllowManualReplace     Boolean @default(true)

  // Accounts
  accountsAutoAssign           Boolean @default(false)
  accountsRequireRecentSession Boolean @default(true)
  accountsHideCredentials      Boolean @default(true)
  accountsAllowReplace         Boolean @default(true)

  // SMM (API keys live on SmmProvider / env)
  smmAutoSend          Boolean @default(false)
  smmManualSend        Boolean @default(true)
  smmMaxRetries        Int     @default(3)
  smmAllowPartials     Boolean @default(true)
  smmValidateUrl       Boolean @default(true)
  smmStuckAlertMinutes Int     @default(1440)

  // Email (Resend API key stays in env)
  resendEnabled              Boolean @default(true)
  transactionalEmailsEnabled Boolean @default(true)
  adminEmailsEnabled         Boolean @default(true)
  emailOrderCreated          Boolean @default(true)
  emailPaymentApproved       Boolean @default(true)
  emailPaymentRejected       Boolean @default(true)
  emailDeliveryAvailable     Boolean @default(true)
  emailDeliveryFailed        Boolean @default(true)
  emailPasswordReset         Boolean @default(true)
  emailEmailVerification     Boolean @default(true)

  // Security (session duration remains Better Auth config)
  requireEmailVerifiedForCheckout Boolean @default(false)
  reauthForCredentialReveal       Boolean @default(true)
  auditSettingsChanges            Boolean @default(true)

  // Maintenance (storeStatus=MAINTENANCE is the source of truth for public mode)
  maintenanceMessage                      String?
  estimatedReturnAt                       DateTime?
  allowAdminDuringMaintenance             Boolean   @default(true)
  allowWebhooksDuringMaintenance          Boolean   @default(true)
  allowJobsDuringMaintenance              Boolean   @default(true)
  allowOngoingDeliveriesDuringMaintenance Boolean   @default(true)

  // Admin notifications
  notifyPaymentFailed       Boolean  @default(true)
  notifyPaymentInconsistent Boolean  @default(true)
  notifyDeliveryFailed      Boolean  @default(true)
  notifyPaidWithoutDelivery Boolean  @default(true)
  notifyLowStock            Boolean  @default(true)
  notifyOutOfStock          Boolean  @default(true)
  notifySmmStuck            Boolean  @default(true)
  notifyProviderError       Boolean  @default(true)
  notifyWebhookFailed       Boolean  @default(true)
  notifyHighValueSale       Boolean  @default(true)
  highValueSaleThreshold    Decimal? @db.Decimal(12, 2)
  adminNotificationEmails   String?

  /// Optimistic concurrency for partial section updates
  version Int @default(1)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("store_settings")
}

model AdminSettingsEvent {
  id          String   @id @default(cuid())
  section     String
  action      String
  actorUserId String?
  actorEmail  String?
  changes     Json?
  message     String?
  result      String   @default("success")
  createdAt   DateTime @default(now())

  @@index([section, createdAt])
  @@index([actorUserId, createdAt])
  @@index([createdAt])
  @@map("admin_settings_events")
}

// ---------------------------------------------------------------------------
// Operational communications (email, web push, templates and consent)
// ---------------------------------------------------------------------------

enum CommunicationChannel {
  EMAIL
  WEB_PUSH
  LIVE_CHAT
}

enum CommunicationDirection {
  INBOUND
  OUTBOUND
  INTERNAL
}

enum CommunicationKind {
  OPERATIONAL
  MARKETING
  SECURITY
  SUPPORT
  SYSTEM
}

enum CommunicationThreadStatus {
  OPEN
  PENDING
  RESOLVED
  ARCHIVED
  SPAM
}

enum CommunicationPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum EmailMessageStatus {
  DRAFT
  QUEUED
  ACCEPTED
  SENT
  DELIVERED
  DELAYED
  BOUNCED
  COMPLAINED
  FAILED
  CANCELLED
}

enum WebPushStatus {
  DRAFT
  SCHEDULED
  QUEUED
  SENDING
  SENT
  PARTIALLY_SENT
  FAILED
  CANCELLED
  ARCHIVED
}

enum CommunicationAudienceType {
  ALL_ELIGIBLE
  SPECIFIC_USERS
  INTERNAL_SEGMENT
  ONESIGNAL_SEGMENT
}

enum CommunicationTemplateChannel {
  EMAIL
  WEB_PUSH
}

enum CommunicationTemplateStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum WebPushPermissionStatus {
  UNSUPPORTED
  DEFAULT
  GRANTED
  DENIED
  UNAVAILABLE
}

model CommunicationThread {
  id             String                      @id @default(cuid())
  subject        String
  status         CommunicationThreadStatus   @default(OPEN)
  priority       CommunicationPriority       @default(NORMAL)
  channel        CommunicationChannel        @default(EMAIL)
  category       String?
  userId         String?
  user           User?                       @relation(fields: [userId], references: [id], onDelete: SetNull)
  orderId        String?
  order          Order?                      @relation(fields: [orderId], references: [id], onDelete: SetNull)
  deliveryId     String?
  delivery       Delivery?                   @relation(fields: [deliveryId], references: [id], onDelete: SetNull)
  assignedUserId String?
  assignedEmail  String?
  unreadCount    Int                         @default(0)
  lastMessageAt  DateTime
  lastInboundAt  DateTime?
  lastOutboundAt DateTime?
  resolvedAt     DateTime?
  archivedAt     DateTime?
  spamAt         DateTime?
  deletedAt      DateTime?
  messages       CommunicationMessage[]
  notes          CommunicationInternalNote[]
  createdAt      DateTime                    @default(now())
  updatedAt      DateTime                    @updatedAt

  @@index([status, lastMessageAt])
  @@index([channel, status, lastMessageAt])
  @@index([userId, lastMessageAt])
  @@index([assignedUserId, status])
  @@index([orderId])
  @@index([deliveryId])
  @@map("communication_threads")
}

model CommunicationMessage {
  id                String                        @id @default(cuid())
  threadId          String?
  thread            CommunicationThread?          @relation(fields: [threadId], references: [id], onDelete: SetNull)
  channel           CommunicationChannel          @default(EMAIL)
  direction         CommunicationDirection
  kind              CommunicationKind             @default(SUPPORT)
  status            EmailMessageStatus
  provider          String?
  externalId        String?
  idempotencyKey    String?                       @unique
  fromAddress       String?
  fromName          String?
  toAddresses       Json
  ccAddresses       Json?
  bccAddresses      Json?
  replyToAddress    String?
  subject           String
  textContent       String
  sanitizedHtml     String?
  remoteImages      Boolean                       @default(false)
  providerMetadata  Json?
  sentByUserId      String?
  sentByEmail       String?
  templateVersionId String?
  templateVersion   CommunicationTemplateVersion? @relation(fields: [templateVersionId], references: [id], onDelete: SetNull)
  scheduledAt       DateTime?
  queuedAt          DateTime?
  acceptedAt        DateTime?
  sentAt            DateTime?
  deliveredAt       DateTime?
  failedAt          DateTime?
  deletedAt         DateTime?
  attachments       CommunicationAttachment[]
  events            CommunicationEmailEvent[]
  createdAt         DateTime                      @default(now())
  updatedAt         DateTime                      @updatedAt

  @@unique([provider, externalId])
  @@index([threadId, createdAt])
  @@index([status, createdAt])
  @@index([scheduledAt, status])
  @@map("communication_messages")
}

model CommunicationInternalNote {
  id           String              @id @default(cuid())
  threadId     String
  thread       CommunicationThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  authorUserId String
  authorEmail  String
  content      String
  deletedAt    DateTime?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  @@index([threadId, createdAt])
  @@map("communication_internal_notes")
}

model CommunicationAttachment {
  id         String               @id @default(cuid())
  messageId  String
  message    CommunicationMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  providerId String?
  objectKey  String?
  fileName   String
  mimeType   String
  sizeBytes  BigInt
  contentId  String?
  inline     Boolean              @default(false)
  scanStatus String               @default("NOT_AVAILABLE")
  createdAt  DateTime             @default(now())

  @@index([messageId])
  @@map("communication_attachments")
}

model CommunicationEmailEvent {
  id              String               @id @default(cuid())
  messageId       String
  message         CommunicationMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  providerEventId String               @unique
  type            String
  occurredAt      DateTime
  safeMetadata    Json?
  createdAt       DateTime             @default(now())

  @@index([messageId, occurredAt])
  @@index([type, occurredAt])
  @@map("communication_email_events")
}

model WebPushNotification {
  id                     String                        @id @default(cuid())
  name                   String
  title                  String
  body                   String
  kind                   CommunicationKind
  status                 WebPushStatus                 @default(DRAFT)
  targetUrl              String?
  iconUrl                String?
  imageUrl               String?
  buttons                Json?
  data                   Json
  language               String                        @default("es")
  timezone               String                        @default("America/Santiago")
  priority               Int                           @default(5)
  ttlSeconds             Int?
  audienceType           CommunicationAudienceType
  audienceDefinition     Json
  estimatedRecipients    Int?
  excludedRecipients     Int                           @default(0)
  externalId             String?                       @unique
  idempotencyKey         String?                       @unique
  scheduledAt            DateTime?
  queuedAt               DateTime?
  sendingAt              DateTime?
  sentAt                 DateTime?
  cancelledAt            DateTime?
  archivedAt             DateTime?
  deletedAt              DateTime?
  recipients             Int                           @default(0)
  successful             Int                           @default(0)
  failed                 Int                           @default(0)
  delivered              Int                           @default(0)
  clicked                Int                           @default(0)
  lastProviderSyncAt     DateTime?
  providerError          String?
  replacedNotificationId String?
  createdByUserId        String
  createdByEmail         String
  updatedByUserId        String?
  updatedByEmail         String?
  templateVersionId      String?
  templateVersion        CommunicationTemplateVersion? @relation(fields: [templateVersionId], references: [id], onDelete: SetNull)
  createdAt              DateTime                      @default(now())
  updatedAt              DateTime                      @updatedAt

  @@index([status, scheduledAt])
  @@index([createdByUserId, createdAt])
  @@index([createdAt])
  @@map("web_push_notifications")
}

model CommunicationTemplate {
  id              String                         @id @default(cuid())
  name            String
  slug            String                         @unique
  channel         CommunicationTemplateChannel
  kind            CommunicationKind
  status          CommunicationTemplateStatus    @default(DRAFT)
  currentVersion  Int                            @default(1)
  createdByUserId String
  createdByEmail  String
  updatedByUserId String?
  updatedByEmail  String?
  archivedAt      DateTime?
  deletedAt       DateTime?
  versions        CommunicationTemplateVersion[]
  createdAt       DateTime                       @default(now())
  updatedAt       DateTime                       @updatedAt

  @@index([channel, status])
  @@map("communication_templates")
}

model CommunicationTemplateVersion {
  id              String                 @id @default(cuid())
  templateId      String
  template        CommunicationTemplate  @relation(fields: [templateId], references: [id], onDelete: Cascade)
  version         Int
  subject         String?
  title           String?
  content         String
  textContent     String?
  variables       String[]               @default([])
  changeReason    String?
  createdByUserId String
  createdByEmail  String
  messages        CommunicationMessage[]
  notifications   WebPushNotification[]
  createdAt       DateTime               @default(now())

  @@unique([templateId, version])
  @@index([templateId, createdAt])
  @@map("communication_template_versions")
}

model CommunicationAudienceSegment {
  id                  String    @id @default(cuid())
  name                String
  description         String?
  definition          Json
  estimatedRecipients Int?
  excludedRecipients  Int       @default(0)
  estimatedAt         DateTime?
  createdByUserId     String
  createdByEmail      String
  updatedByUserId     String?
  updatedByEmail      String?
  archivedAt          DateTime?
  deletedAt           DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([archivedAt, updatedAt])
  @@map("communication_audience_segments")
}

model CommunicationPreference {
  id                 String    @id @default(cuid())
  userId             String    @unique
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  marketingEmail     Boolean   @default(false)
  webPushEnabled     Boolean   @default(false)
  orders             Boolean   @default(true)
  payments           Boolean   @default(true)
  deliveries         Boolean   @default(true)
  smm                Boolean   @default(true)
  security           Boolean   @default(true)
  newProducts        Boolean   @default(false)
  promotions         Boolean   @default(false)
  marketingConsentAt DateTime?
  marketingOptOutAt  DateTime?
  consentSource      String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@index([marketingEmail])
  @@index([webPushEnabled])
  @@map("communication_preferences")
}

model WebPushSubscription {
  id                       String                  @id @default(cuid())
  userId                   String?
  user                     User?                   @relation(fields: [userId], references: [id], onDelete: SetNull)
  provider                 String                  @default("ONESIGNAL")
  providerSubscriptionId   String?                 @unique
  providerSubscriptionHash String?                 @unique
  permissionStatus         WebPushPermissionStatus @default(DEFAULT)
  optedIn                  Boolean                 @default(false)
  browser                  String?
  platform                 String?
  lastSeenAt               DateTime?
  subscribedAt             DateTime?
  unsubscribedAt           DateTime?
  createdAt                DateTime                @default(now())
  updatedAt                DateTime                @updatedAt

  @@index([userId, optedIn])
  @@index([permissionStatus])
  @@map("web_push_subscriptions")
}

model CommunicationAuditEvent {
  id                  String                @id @default(cuid())
  actorUserId         String?
  actorEmail          String?
  action              String
  channel             CommunicationChannel?
  resourceType        String
  resourceId          String
  statusBefore        String?
  statusAfter         String?
  audienceSummary     Json?
  estimatedRecipients Int?
  affectedRecipients  Int?
  maskedRecipient     String?
  externalIdSuffix    String?
  result              String                @default("SUCCESS")
  errorCode           String?
  safeMetadata        Json?
  createdAt           DateTime              @default(now())

  @@index([resourceType, resourceId, createdAt])
  @@index([actorUserId, createdAt])
  @@index([action, createdAt])
  @@map("communication_audit_events")
}

model CommunicationWebhookEvent {
  id                 String    @id @default(cuid())
  provider           String
  externalEventId    String
  eventType          String
  resourceExternalId String?
  status             String    @default("PROCESSED")
  errorCode          String?
  receivedAt         DateTime  @default(now())
  processedAt        DateTime?

  @@unique([provider, externalEventId])
  @@index([provider, eventType, receivedAt])
  @@index([status, receivedAt])
  @@map("communication_webhook_events")
}
