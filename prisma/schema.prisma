// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------------------------
// Better Auth core schema
// https://www.better-auth.com/docs/concepts/database#core-schema
// ---------------------------------------------------------------------------

enum UserRole {
  USER
  ADMIN
}

/// Administrative access state (independent of Better Auth session validity).
enum UserAccountStatus {
  ACTIVE
  RESTRICTED
  SUSPENDED
  ANONYMIZED
}

enum UserAdminNoteCategory {
  SUPPORT
  RISK
  FRAUD
  BILLING
  DELIVERY
  REFUND
  OTHER
}

enum UserAdminNotePriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum UserAdminEventType {
  ACCOUNT_CREATED
  EMAIL_VERIFIED
  PROFILE_UPDATED
  BILLING_UPDATED
  ROLE_CHANGED
  ACCOUNT_RESTRICTED
  ACCOUNT_SUSPENDED
  ACCOUNT_RESTORED
  SESSION_REVOKED
  SESSIONS_REVOKED_ALL
  PASSWORD_RESET_SENT
  EMAIL_VERIFICATION_SENT
  NOTE_ADDED
  NOTE_UPDATED
  NOTE_RESOLVED
  NOTE_REOPENED
  NOTE_DELETED
  REVIEW_MARKED
  REVIEW_RESOLVED
  ANONYMIZED
  OAUTH_UNLINKED
}

/// Preferred Chilean tax document for checkout (SII DTE).
enum InvoiceDocumentType {
  BOLETA
  FACTURA
}

model User {
  id            String   @id
  name          String
  email         String
  emailVerified Boolean  @default(false)
  image         String?
  role          UserRole @default(USER)

  accountStatus     UserAccountStatus @default(ACTIVE)
  suspensionReason  String?
  suspendedAt       DateTime?
  suspendedByUserId String?
  suspensionEndsAt  DateTime?
  requiresReview    Boolean           @default(false)
  reviewReason      String?
  lastActivityAt    DateTime?
  anonymizedAt      DateTime?

  /// Chilean RUT normalized as "12345678-9" (optional for boleta; required for factura / >135 UF).
  rut              String?
  phone            String?
  /// Default document type at checkout.
  invoiceType      InvoiceDocumentType @default(BOLETA)
  /// Razón social — required when invoiceType is FACTURA.
  businessName     String?
  /// Giro comercial — required when invoiceType is FACTURA.
  businessActivity String?
  addressLine1     String?
  addressLine2     String?
  commune          String?
  city             String?
  region           String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  sessions  Session[]
  accounts  Account[]
  orders    Order[]
  cart      Cart?
  wishlist  Wishlist?
  adminNotes  UserAdminNote[]
  adminEvents UserAdminEvent[]

  @@unique([email])
  @@index([rut])
  @@index([role])
  @@index([accountStatus])
  @@index([createdAt])
  @@index([lastActivityAt])
  @@index([requiresReview])
  @@map("user")
}

model UserAdminNote {
  id           String                @id @default(cuid())
  userId       String
  user         User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  authorUserId String?
  authorEmail  String?
  category     UserAdminNoteCategory
  priority     UserAdminNotePriority @default(MEDIUM)
  content      String
  resolvedAt   DateTime?
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt

  @@index([userId, createdAt])
  @@index([userId, resolvedAt])
  @@map("user_admin_notes")
}

model UserAdminEvent {
  id          String             @id @default(cuid())
  userId      String
  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        UserAdminEventType
  actorUserId String?
  actorEmail  String?
  message     String?
  metadata    Json?
  createdAt   DateTime           @default(now())

  @@index([userId, createdAt])
  @@index([type, createdAt])
  @@map("user_admin_events")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

// ---------------------------------------------------------------------------
// Store enums
// ---------------------------------------------------------------------------

enum DeliveryMethod {
  SMM
  KINGUIN
  MANUAL
}

enum ProductStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum OrderStatus {
  PENDING
  PAID
  PROCESSING
  FULFILLED
  PARTIALLY_FULFILLED
  CANCELED
  REFUNDED
}

enum DeliveryStatus {
  PENDING
  PROCESSING
  DELIVERED
  FAILED
  CANCELED
}

enum DeliveryEventSource {
  SYSTEM
  WEBHOOK
  ADMIN
}

enum DeliveryContentType {
  PRODUCT_KEY
  CODE
  PIN
  USERNAME_PASSWORD
  EMAIL_PASSWORD
  TOKEN
  URL
  INSTRUCTIONS
  FREE_TEXT
  OTHER
}

enum DeliveryNotificationType {
  COMPLETED
  FAILED
  PROCESSING
}

enum DeliveryNotificationStatus {
  PENDING
  SENT
  FAILED
}

enum ProductKeyStatus {
  AVAILABLE
  RESERVED
  SOLD
  REVOKED
}

enum PaymentStatus {
  PENDING
  PROCESSING
  PAID
  FAILED
  REJECTED
  CANCELLED
  EXPIRED
  PARTIALLY_REFUNDED
  REFUNDED
}

enum PaymentProvider {
  MANUAL
  FLOW
  OTHER
}

enum PaymentEventType {
  CREATED
  SESSION_STARTED
  CALLBACK_RECEIVED
  WEBHOOK_RECEIVED
  PROVIDER_STATUS_CHECKED
  STATUS_CHANGED
  ORDER_MARKED_PAID
  FULFILLMENT_STARTED
  RECONCILED
  CONFIRMATION_REPROCESSED
  REVIEW_MARKED
  REVIEW_RESOLVED
  NOTE_ADDED
  REFUND_REQUESTED
  REFUND_STATUS_CHECKED
  REFUND_COMPLETED
  MANUAL_CORRECTION
  ERROR
}

enum PaymentEventSource {
  SYSTEM
  CALLBACK
  WEBHOOK
  PROVIDER
  ADMIN
}

enum PaymentEventResult {
  SUCCESS
  PARTIAL
  FAILED
  IGNORED
}

enum PaymentReviewPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum PaymentRefundStatus {
  CREATED
  ACCEPTED
  REJECTED
  REFUNDED
  CANCELLED
  ERROR
}

enum SmmProviderStatus {
  ACTIVE
  INACTIVE
  ERROR
}

/// Direction of a persisted catalog price change (for UI / user notices).
enum PriceChangeDirection {
  UP
  DOWN
}

enum AssetType {
  IMAGE
  VIDEO
  YOUTUBE
}

// ---------------------------------------------------------------------------
// SMM providers & catalog services
// ---------------------------------------------------------------------------

model SmmProvider {
  id           String            @id @default(cuid())
  name         String
  slug         String            @unique
  description  String?
  apiUrl       String
  apiKey       String
  status       SmmProviderStatus @default(ACTIVE)
  isDefault    Boolean           @default(false)
  lastSyncedAt DateTime?
  lastError    String?
  services     SmmService[]
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@index([status])
  @@index([slug])
  @@map("smm_provider")
}

/// Cached remote service from an SMM panel (`SmmServiceItem`).
model SmmService {
  id              String      @id @default(cuid())
  providerId      String
  provider        SmmProvider @relation(fields: [providerId], references: [id], onDelete: Cascade)
  remoteServiceId Int
  name            String
  type            String
  category        String
  rate            Decimal     @db.Decimal(18, 6)
  min             Int
  max             Int
  refill          Boolean     @default(false)
  cancel          Boolean     @default(false)
  isActive        Boolean     @default(true)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@unique([providerId, remoteServiceId])
  @@index([providerId, category])
  @@index([providerId, name])
  @@index([remoteServiceId])
  @@map("smm_service")
}

// ---------------------------------------------------------------------------
// Catalog
// ---------------------------------------------------------------------------

model Category {
  id          String            @id @default(cuid())
  name        String
  slug        String            @unique
  description String?
  imageUrl    String?
  parentId    String?
  parent      Category?         @relation("CategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children    Category[]        @relation("CategoryTree")
  products    ProductCategory[]
  assets      Asset[]
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([parentId])
  @@index([slug])
  @@map("category")
}

model Product {
  id             String         @id @default(cuid())
  name           String
  slug           String         @unique
  description    String?
  coverImageUrl  String?
  status         ProductStatus  @default(DRAFT)
  deliveryMethod DeliveryMethod

  price          Decimal  @db.Decimal(12, 2)
  compareAtPrice Decimal? @db.Decimal(12, 2)
  currency       String   @default("CLP")
  qty            Int      @default(0)
  textQty        Int?

  isFeatured Boolean @default(false)
  isOffer    Boolean @default(false)
  isPreorder Boolean @default(false)

  originalName        String?
  platform            String?
  genres              String[]  @default([])
  languages           String[]  @default([])
  developers          String[]  @default([])
  publishers          String[]  @default([])
  tags                String[]  @default([])
  regionId            Int?
  regionalLimitations String?
  countryLimitation   String[]  @default([])
  releaseDate         DateTime?
  activationDetails   String?
  ageRating           String?
  metacriticScore     Int?
  sourceCostPrice     Decimal?  @db.Decimal(12, 4)

  // Kinguin remote ids / sync
  kinguinProductId String?   @unique
  kinguinId        Int?      @unique
  kinguinOfferId   String?
  /// Markup % applied when pricing from Kinguin default offer EUR cost.
  kinguinMarkupPct Decimal?  @db.Decimal(8, 2)
  kinguinSyncedAt  DateTime?

  // SMM panel mapping / sync
  smmApiUrl      String?
  smmServiceId   Int?
  smmServiceType String?
  smmCategory    String?
  smmRate        Decimal?  @db.Decimal(18, 6)
  /// Markup % applied when pricing from SMM rate (e.g. 54 → ×1.54). Used to reprice on rate sync.
  smmMarkupPct   Decimal?  @db.Decimal(8, 2)
  smmMin         Int?
  smmMax         Int?
  smmRefill      Boolean?
  smmCancel      Boolean?
  smmServiceName String?
  smmSyncedAt    DateTime?

  categories         ProductCategory[]
  assets             Asset[]
  systemRequirements ProductSystemRequirement[]
  keys               ProductKey[]
  offers             ProductOffer[]
  orderItems         OrderItem[]
  cartItems          CartItem[]
  wishlistItems      WishlistItem[]
  priceChangeEvents  ProductPriceChangeEvent[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([deliveryMethod])
  @@index([slug])
  @@index([smmServiceId])
  @@map("product")
}

/// Short-lived audit of product price moves (cleaned by cron after retention).
/// Used to show % up/down and later notify users (cart / wishlist / etc.).
model ProductPriceChangeEvent {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  /// e.g. "smm.service.rate_changed"
  source String

  oldPrice Decimal @db.Decimal(12, 2)
  newPrice Decimal @db.Decimal(12, 2)
  currency String  @default("CLP")

  /// Relative change: ((new - old) / old) * 100. Positive = up, negative = down.
  changePct Decimal              @db.Decimal(12, 4)
  direction PriceChangeDirection

  oldSmmRate   Decimal? @db.Decimal(18, 6)
  newSmmRate   Decimal? @db.Decimal(18, 6)
  smmMarkupPct Decimal? @db.Decimal(8, 2)

  remoteServiceId Int?
  providerId      String?

  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([productId, createdAt])
  @@index([direction, createdAt])
  @@map("product_price_change_event")
}

model ProductCategory {
  id         String   @id @default(cuid())
  productId  String
  categoryId String
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([productId, categoryId])
  @@index([categoryId])
  @@map("product_category")
}

model Asset {
  id           String    @id @default(cuid())
  type         AssetType
  url          String
  objectKey    String?   @unique
  youtubeId    String?
  mimeType     String?
  fileName     String?
  sizeBytes    BigInt?
  thumbnailUrl String?
  altText      String?
  sortOrder    Int       @default(0)
  isCover      Boolean   @default(false)
  productId    String?
  product      Product?  @relation(fields: [productId], references: [id], onDelete: Cascade)
  categoryId   String?
  category     Category? @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([productId, sortOrder])
  @@index([categoryId, sortOrder])
  @@map("asset")
}

model ProductSystemRequirement {
  id           String   @id @default(cuid())
  productId    String
  product      Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  system       String
  requirements String[] @default([])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([productId])
  @@map("product_system_requirement")
}

model ProductKey {
  id           String           @id @default(cuid())
  productId    String
  product      Product          @relation(fields: [productId], references: [id], onDelete: Cascade)
  code         String
  status       ProductKeyStatus @default(AVAILABLE)
  orderItemId  String?
  orderItem    OrderItem?       @relation(fields: [orderItemId], references: [id], onDelete: SetNull)
  deliveryKeys DeliveryKey[]
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@unique([productId, code])
  @@index([productId, status])
  @@index([orderItemId])
  @@map("product_key")
}

model ProductOffer {
  id             String    @id @default(cuid())
  productId      String
  product        Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  kinguinOfferId String    @unique
  price          Decimal   @db.Decimal(12, 4)
  qty            Int       @default(0)
  textQty        Int       @default(0)
  availableQty   Int?
  isPreorder     Boolean   @default(false)
  releaseDate    DateTime?
  merchantName   String?
  isDefault      Boolean   @default(false)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([productId])
  @@map("product_offer")
}

// ---------------------------------------------------------------------------
// Orders & delivery
// ---------------------------------------------------------------------------

model Order {
  id           String      @id @default(cuid())
  userId       String
  user         User        @relation(fields: [userId], references: [id], onDelete: Restrict)
  status       OrderStatus @default(PENDING)
  subtotal     Decimal     @db.Decimal(12, 2)
  total        Decimal     @db.Decimal(12, 2)
  currency     String      @default("CLP")
  email        String
  customerName String?
  items        OrderItem[]
  payments     Payment[]
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@index([userId, status])
  @@index([status])
  @@map("order")
}

model OrderItem {
  id             String         @id @default(cuid())
  orderId        String
  order          Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId      String
  product        Product        @relation(fields: [productId], references: [id], onDelete: Restrict)
  productName    String
  unitPrice      Decimal        @db.Decimal(12, 2)
  quantity       Int
  deliveryMethod DeliveryMethod
  smm            OrderItemSmm?
  delivery       Delivery?
  productKeys    ProductKey[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([orderId])
  @@index([productId])
  @@map("order_item")
}

model OrderItemSmm {
  id              String    @id @default(cuid())
  orderItemId     String    @unique
  orderItem       OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  link            String?
  username        String?
  quantity        Int?
  comments        String?
  runs            Int?
  intervalMinutes Int?
  usernames       String?
  hashtags        String?
  mediaUrl        String?
  min             Int?
  max             Int?
  delayMinutes    Int?
  posts           Int?
  oldPosts        Int?
  expiry          String?
  answerNumber    String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@map("order_item_smm")
}

model Delivery {
  id              String         @id @default(cuid())
  orderItemId     String         @unique
  orderItem       OrderItem      @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  status          DeliveryStatus @default(PENDING)
  deliveryMethod  DeliveryMethod
  errorMessage    String?
  deliveredAt     DateTime?
  customerMessage String?
  lastSyncedAt    DateTime?

  // Remote order refs (Kinguin / SMM)
  externalOrderId String?
  externalStatus  String?
  kinguinOrderId  String?
  orderExternalId String?
  requestPriceEur Decimal? @db.Decimal(12, 4)

  // SMM progress / cost
  smmCharge     Decimal? @db.Decimal(12, 4)
  smmStartCount Int?
  smmRemains    Int?
  smmCurrency   String?
  smmRefillId   String?

  keys          DeliveryKey[]
  credentials   DeliveryCredential[]
  events        DeliveryEvent[]
  notifications DeliveryNotification[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([deliveryMethod])
  @@index([externalOrderId])
  @@index([createdAt])
  @@index([updatedAt])
  @@map("delivery")
}

model DeliveryKey {
  id            String              @id @default(cuid())
  deliveryId    String
  delivery      Delivery            @relation(fields: [deliveryId], references: [id], onDelete: Cascade)
  serial        String
  /// Legacy / remote type string (e.g. Kinguin key type). Prefer `contentType`.
  type          String?
  contentType   DeliveryContentType @default(PRODUCT_KEY)
  label         String?
  instructions  String?
  isSecret      Boolean             @default(true)
  externalKeyId String?
  productKeyId  String?
  productKey    ProductKey?         @relation(fields: [productKeyId], references: [id], onDelete: SetNull)
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  @@unique([productKeyId])
  @@unique([externalKeyId])
  @@index([deliveryId])
  @@map("delivery_key")
}

/// Structured credentials for MANUAL deliveries (passwords/tokens encrypted at rest).
model DeliveryCredential {
  id                String              @id @default(cuid())
  deliveryId        String
  delivery          Delivery            @relation(fields: [deliveryId], references: [id], onDelete: Cascade)
  contentType       DeliveryContentType @default(USERNAME_PASSWORD)
  label             String?
  username          String?
  email             String?
  /// AES-256-GCM ciphertext (base64): iv.authTag.ciphertext
  passwordEncrypted String?
  tokenEncrypted    String?
  url               String?
  notes             String?
  instructions      String?
  isSecret          Boolean             @default(true)
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  @@index([deliveryId])
  @@map("delivery_credential")
}

model DeliveryEvent {
  id          String              @id @default(cuid())
  deliveryId  String
  delivery    Delivery            @relation(fields: [deliveryId], references: [id], onDelete: Cascade)
  status      DeliveryStatus
  message     String?
  source      DeliveryEventSource @default(SYSTEM)
  actorUserId String?
  actorEmail  String?
  createdAt   DateTime            @default(now())

  @@index([deliveryId, createdAt])
  @@index([actorUserId])
  @@map("delivery_event")
}

/// Idempotent email notification log for delivery lifecycle emails.
model DeliveryNotification {
  id             String                     @id @default(cuid())
  deliveryId     String
  delivery       Delivery                   @relation(fields: [deliveryId], references: [id], onDelete: Cascade)
  type           DeliveryNotificationType
  status         DeliveryNotificationStatus @default(PENDING)
  recipient      String
  idempotencyKey String                     @unique
  resendId       String?
  errorMessage   String?
  isResend       Boolean                    @default(false)
  sentAt         DateTime?
  createdAt      DateTime                   @default(now())
  updatedAt      DateTime                   @updatedAt

  @@index([deliveryId, type])
  @@index([status])
  @@map("delivery_notification")
}

// ---------------------------------------------------------------------------
// Payments
// ---------------------------------------------------------------------------

model Payment {
  id                  String                 @id @default(cuid())
  orderId             String
  order               Order                  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  provider            PaymentProvider        @default(OTHER)
  status              PaymentStatus          @default(PENDING)
  amount              Decimal                @db.Decimal(12, 2)
  currency            String                 @default("CLP")
  externalId          String?
  flowOrder           Int?
  commerceOrder       String?
  paymentMethod       String?
  payerEmail          String?
  providerStatus      String?
  paidAt              DateTime?
  expiresAt           DateTime?
  confirmedAt         DateTime?
  lastProviderCheckAt DateTime?
  refundAmount        Decimal                @default(0) @db.Decimal(12, 2)
  safeMetadata        Json?
  requiresReview      Boolean                @default(false)
  reviewPriority      PaymentReviewPriority?
  reviewReason        String?
  reviewNote          String?
  reviewActorUserId   String?
  reviewActorEmail    String?
  reviewCreatedAt     DateTime?
  reviewResolvedAt    DateTime?
  failureCode         String?
  failureMessage      String?
  events              PaymentEvent[]
  refunds             PaymentRefund[]
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt

  @@unique([provider, externalId])
  @@index([orderId])
  @@index([externalId])
  @@index([flowOrder])
  @@index([commerceOrder])
  @@index([status])
  @@index([requiresReview, reviewPriority])
  @@index([createdAt])
  @@map("payment")
}

model PaymentEvent {
  id             String             @id @default(cuid())
  paymentId      String
  payment        Payment            @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  type           PaymentEventType
  source         PaymentEventSource @default(SYSTEM)
  result         PaymentEventResult @default(SUCCESS)
  statusBefore   PaymentStatus?
  statusAfter    PaymentStatus?
  message        String?
  actorUserId    String?
  actorEmail     String?
  providerRef    String?
  errorCode      String?
  idempotencyKey String?            @unique
  createdAt      DateTime           @default(now())

  @@index([paymentId, createdAt])
  @@index([type, createdAt])
  @@index([actorUserId])
  @@map("payment_event")
}

model PaymentRefund {
  id                  String              @id @default(cuid())
  paymentId           String
  payment             Payment             @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  amount              Decimal             @db.Decimal(12, 2)
  currency            String
  reason              String
  status              PaymentRefundStatus @default(CREATED)
  refundCommerceOrder String              @unique
  flowRefundOrder     String?
  providerToken       String?             @unique
  providerMessage     String?
  actorUserId         String?
  actorEmail          String?
  requestedAt         DateTime            @default(now())
  completedAt         DateTime?
  updatedAt           DateTime            @updatedAt

  @@index([paymentId, status])
  @@index([status, requestedAt])
  @@map("payment_refund")
}

// ---------------------------------------------------------------------------
// Cart
// ---------------------------------------------------------------------------

model Cart {
  id        String     @id @default(cuid())
  userId    String     @unique
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     CartItem[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@map("cart")
}

model CartItem {
  id        String       @id @default(cuid())
  cartId    String
  cart      Cart         @relation(fields: [cartId], references: [id], onDelete: Cascade)
  productId String
  product   Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantity  Int          @default(1)
  smm       CartItemSmm?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  // No @@unique([cartId, productId]): SMM can add the same product with different links.
  @@index([cartId])
  @@index([productId])
  @@map("cart_item")
}

model CartItemSmm {
  id              String   @id @default(cuid())
  cartItemId      String   @unique
  cartItem        CartItem @relation(fields: [cartItemId], references: [id], onDelete: Cascade)
  link            String?
  username        String?
  quantity        Int?
  comments        String?
  runs            Int?
  intervalMinutes Int?
  usernames       String?
  hashtags        String?
  mediaUrl        String?
  min             Int?
  max             Int?
  delayMinutes    Int?
  posts           Int?
  oldPosts        Int?
  expiry          String?
  answerNumber    String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("cart_item_smm")
}

// ---------------------------------------------------------------------------
// Wishlist
// ---------------------------------------------------------------------------

model Wishlist {
  id        String         @id @default(cuid())
  userId    String         @unique
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     WishlistItem[]
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@map("wishlist")
}

model WishlistItem {
  id         String   @id @default(cuid())
  wishlistId String
  wishlist   Wishlist @relation(fields: [wishlistId], references: [id], onDelete: Cascade)
  productId  String
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([wishlistId, productId])
  @@index([productId])
  @@map("wishlist_item")
}
