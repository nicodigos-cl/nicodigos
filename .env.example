# Cloudflare Turnstile (test keys always pass — replace for production)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA

# App
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000
# Public site URL used for Flow return/confirmation callbacks
# NEXT_PUBLIC_APP_URL=http://localhost:3000

# Flow.cl payments (@nicotordev/flowcl-pagos)
FLOW_API_KEY=
FLOW_SECRET_KEY=
# sandbox | production
FLOW_ENVIRONMENT=sandbox

# Comma-separated admin emails and/or domains
# e.g. admin@nicodigos.com,nicotordev.com
ADMIN_EMAILS=

# Email (Resend + react-email)
RESEND_API_KEY=
# e.g. Nicodigos <onboarding@resend.dev> or your verified domain
RESEND_FROM=Nicodigos <onboarding@resend.dev>
# Signing secret (whsec_...) for POST /api/webhooks/resend
RESEND_WEBHOOK_SECRET=

# OneSignal web push. NEXT_PUBLIC value is only the public App ID.
NEXT_PUBLIC_ONESIGNAL_APP_ID=
ONESIGNAL_APP_ID=
ONESIGNAL_REST_API_KEY=
# Only needed for organization-level OneSignal operations (not used by the app today).
# ONESIGNAL_ORGANIZATION_API_KEY=

# AES-256-GCM key material for delivery credentials (passwords/tokens).
# Use a long random secret (32+ chars). Required to save/reveal MANUAL credentials.
# DELIVERY_SECRETS_KEY=

# Optional OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# Use a dedicated/empty database for this schema (do not point at the old ecommerce DB).
# Fresh DB:
#   createdb nicodigos_store
#   DATABASE_URL=postgresql://postgres:postgres@localhost:5432/nicodigos_store
#   bunx --bun prisma migrate deploy
# Or in local empty DB: bunx --bun prisma migrate dev
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/nicodigos_store
# Railway (Railpack): private networking is unavailable at build time.
# Keep DATABASE_URL as the private URL for runtime + pre-deploy migrations.
# Set DATABASE_PUBLIC_URL for `next build` prerender (see railway.toml):
#   DATABASE_PUBLIC_URL=${{Postgres.DATABASE_PUBLIC_URL}}
# DATABASE_PUBLIC_URL=

# Kinguin ESA API (https://www.kinguin.net/integration)
KINGUIN_API_KEY=
# production (default) | sandbox
KINGUIN_ENVIRONMENT=sandbox
# Optional override (defaults from KINGUIN_ENVIRONMENT):
# KINGUIN_API_BASE=https://gateway.sandbox.kinguin.net/esa/api

# Logging (pino) — fatal|error|warn|info|debug|trace
LOG_LEVEL=debug
SERVICE_NAME=nicodigos

# Sentry error monitoring (server-side)
# Create a project at https://sentry.io → Settings → Client Keys (DSN)
SENTRY_DSN=
# Tag events so they don't mix: development | production | staging
# On Railway this defaults to RAILWAY_ENVIRONMENT_NAME (e.g. production).
# Locally, NODE_ENV=development is used if unset.
# SENTRY_ENVIRONMENT=development
# Client-side tag (optional; falls back to NODE_ENV)
# NEXT_PUBLIC_SENTRY_ENVIRONMENT=development
# Optional client DSN override (defaults to SENTRY_DSN)
# NEXT_PUBLIC_SENTRY_DSN=
# Optional: 0–1 sample rate for performance traces (default 0 = errors only)
# SENTRY_TRACES_SAMPLE_RATE=0
# SERVICE_VERSION=local

# OpenAI (SMM → product translate / markup)
OPENAI_API_KEY=
# Optional override (default: gpt-5-nano)
# OPENAI_MODEL=gpt-5-nano

# Redis (FX cache + BullMQ + live support pub/sub)
REDIS_URL=redis://127.0.0.1:6379
# BULLMQ_PREFIX=nicodigos
# DELIVERY_WORKER_CONCURRENCY=5
# EMAIL_WORKER_CONCURRENCY=5
# DELIVERY_RECONCILE_DELAY_MS=300000
# DELIVERY_RECONCILE_MAX_ATTEMPTS=2016

# Live support WebSocket gateway (dedicated Railway service)
# SUPPORT_WS_SECRET=generate-a-long-random-secret
# NEXT_PUBLIC_SUPPORT_WS_URL=ws://127.0.0.1:3011/ws
# In production use wss://<support-ws-public-domain>/ws
# PORT=3011

# Cloudflare R2 (S3 API credentials + public bucket/custom-domain URL)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
# e.g. https://media.nicodigos.com
R2_PUBLIC_URL=

# Cron endpoints (Authorization: Bearer <CRON_SECRET>)
# POST/GET /api/cron/sync-smm-services
# POST/GET /api/cron/sync-kinguin-products
# POST/GET /api/cron/cleanup-price-change-events
# POST/GET /api/cron/process-communications
# POST/GET /api/cron/publish-outbox
CRON_SECRET=

# Keep product price-change events this many days (default 7). Cleanup runs after sync cron.
# PRICE_CHANGE_EVENT_RETENTION_DAYS=7

# Dev cron pollers
# CRON_BASE_URL=http://localhost:3000
# CRON_SYNC_SMM_INTERVAL_MS=300000
# CRON_SYNC_SMM_INITIAL_DELAY_MS=8000
# CRON_SYNC_KINGUIN_INTERVAL_MS=600000
# CRON_SYNC_KINGUIN_INITIAL_DELAY_MS=20000
# CRON_CLEANUP_PRICE_EVENTS_INTERVAL_MS=86400000
# CRON_CLEANUP_PRICE_EVENTS_INITIAL_DELAY_MS=15000
# CRON_PUBLISH_OUTBOX_INTERVAL_MS=5000
# CRON_PUBLISH_OUTBOX_INITIAL_DELAY_MS=3000

# Sentry error monitoring (client-side)

SENTRY_AUTH_TOKEN=
SENTRY_DSN=
